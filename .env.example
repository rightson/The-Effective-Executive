# Local development defaults. Copy to .env and edit.
# `python3 manage.py db init` will copy this file for you on first run.

# ── Database ──────────────────────────────────────────────────────────────
# Aligned with docker-compose.yml. Start Postgres with: docker compose up -d
DATABASE_URL=postgresql://ee:ee@localhost:5432/effective_executive

# ── Session / cookies ─────────────────────────────────────────────────────
SESSION_TTL_DAYS=30
SECURE_COOKIES=false

# ── Server ────────────────────────────────────────────────────────────────
PORT=8000

# ── Optional: Google sign-in ──────────────────────────────────────────────
# Leave blank to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
